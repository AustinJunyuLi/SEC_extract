__pycache__/
*.pyc
.DS_Store

# Local agent-session state (Claude Code scheduled tasks, transcripts, etc.)
.claude/

# Pipeline outputs (regenerated by run.py)
output/extractions/*.json

# Diff reports (regenerated by scoring/diff.py)
scoring/results/

# Quarto-rendered reports (regenerated from .qmd)
report/*.html

# Linkflow API credentials + running logs
.env*
runlog/
logs/
*.log
