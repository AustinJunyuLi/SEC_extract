__pycache__/
*.pyc
.DS_Store

# Local assistant-session state (scheduled tasks, transcripts, local settings)
.claude/

# Pipeline outputs (regenerated by run.py)
output/audit/
output/extractions/*.json
output/playwright/
output/*.csv

# Per-deal advisory lock file (created on demand by _state_file_lock)
state/*.lock

# Diff reports (regenerated by scoring/diff.py)
scoring/results/

# Generated reports / figures
report/figures/*.png
report/*.html

# Linkflow API credentials + running logs
.env*
!.env.example
runlog/
logs/
*.log
